{
  "name": "skymp-backend",
  "version": "2.0.0",
  "description": "General-purpose backend template for SkyMP launchers and multiplayer servers",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "config:check": "node scripts/validate-config.js",
    "migrate:data": "node scripts/migrate-data.js",
    "data:migrate": "npm run migrate:data --",
    "client:setup": "node scripts/setup-client.js",
    "client:build": "node scripts/merge-files.js",
    "client:populate": "node scripts/populate-files.js",
    "launcher:publish": "node scripts/publish-launcher-update.js",
    "setup": "npm run client:setup",
    "merge": "npm run client:build",
    "populate": "npm run client:populate",
    "publish-launcher": "npm run launcher:publish"
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "cors": "^2.8.5",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.2",
    "ws": "^8.20.0",
    "yaml": "^2.9.0"
  }
}
