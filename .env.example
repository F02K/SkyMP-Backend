# Runtime and project overrides
NODE_ENV=development
# BACKEND_CONFIG=backend.config.json
# SHARED_ENV_PATH=/absolute/path/to/shared.env
PROJECT_NAME=SkyMP Backend
PUBLIC_API_URL=http://localhost:4000
WEBSITE_URL=http://localhost:4001

# HTTP services
PORT=4000
DASHBOARD_ENABLED=true
DASHBOARD_PORT=4002
DASHBOARD_PUBLIC_URL=http://localhost:4002
DASHBOARD_API_BASE_URL=http://localhost:4000
CORS_ORIGINS=*
TRUST_PROXY=false

# Persistent storage
DATA_DIR=data

# SkyMP server
SKYMP_HOST=127.0.0.1
SKYMP_PORT=7777
SKYMP_UI_PORT=3000
SERVER_NAME=SkyMP Server
SERVER_MAX_PLAYERS=100
SERVER_OFFLINE_MODE=false
SERVER_NPC_ENABLED=false
# SERVER_GAMEMODE=Roleplay
SERVER_MASTER_KEY=replace-with-a-strong-random-secret
MASTER_URL=http://localhost:4000
MASTER_API_AUTH_TOKEN=replace-with-a-strong-random-secret

# Discord OAuth and role integration
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4000/api/v2/auth/discord/callback
DISCORD_DASHBOARD_REDIRECT_URI=http://localhost:4000/api/v2/admin/auth/callback
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DASHBOARD_DISCORD_IDS=
WHITELIST_ROLE_ID=
BANNED_ROLE_ID=

# Access policy defaults
SERVER_LOCKED=false
SERVER_LOCKED_ROLE_IDS=
SERVER_LOCKED_ALLOW=

# WebSocket relay
WS_PORT=7778
RELAY_SECRET=replace-with-a-strong-random-secret

# Admin and metrics integrations
ADMIN_URL=http://localhost:5001
ADMIN_TOKEN=
METRICS_USER=
METRICS_PASSWORD=

# Client distribution
CLIENT_REPOSITORY_URL=
CLIENT_SOURCE_DIR=sources/client
CLIENT_OUTPUT_DIR=public/files
CLIENT_ARCHIVE_NAME=skymp-client.zip
SKYMP_BUILD_DATA_DIR=
CLIENT_BRANCH=refs/heads/main

# Launcher updates
LAUNCHER_UPDATE_PUBLIC_URL=http://localhost:4000/launcher-updates
LAUNCHER_UPDATES_DIR=public/launcher-updates

# GitHub webhook
GITHUB_WEBHOOK_SECRET=replace-with-a-strong-random-secret

# Feature switches
FEATURE_DISCORD_BOT=true
FEATURE_WEBSOCKET_RELAY=true
FEATURE_GITHUB_WEBHOOK=true
FEATURE_API_DOCS=true
LEGACY_DIRECT_SESSION_CREATION=false
