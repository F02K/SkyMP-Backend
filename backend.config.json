{
  "$schema": "./backend.config.schema.json",
  "project": {
    "name": "SkyMP Backend",
    "websiteUrl": "http://localhost:4001",
    "publicApiUrl": "http://localhost:4000"
  },
  "http": {
    "port": 4000,
    "corsOrigins": ["*"],
    "trustProxy": false
  },
  "dashboard": {
    "enabled": true,
    "port": 4002,
    "publicUrl": "http://localhost:4002",
    "apiBaseUrl": "http://localhost:4000"
  },
  "skymp": {
    "host": "127.0.0.1",
    "port": 7777,
    "serverName": "SkyMP Server",
    "maxPlayers": 100,
    "offlineMode": false,
    "npcEnabled": false,
    "gamemode": null,
    "masterUrl": "http://localhost:4000"
  },
  "discord": {
    "launcherRedirectUri": "http://localhost:4000/api/v2/auth/discord/callback",
    "dashboardRedirectUri": "http://localhost:4000/api/v2/admin/auth/callback",
    "dashboardUserIds": []
  },
  "access": {
    "serverLocked": false,
    "lockedUserIds": [],
    "lockedRoleIds": []
  },
  "integrations": {
    "adminUrl": "http://localhost:5001",
    "clientBranch": "refs/heads/main"
  },
  "distribution": {
    "clientRepositoryUrl": "",
    "clientSourceDir": "sources/client",
    "clientOutputDir": "public/files",
    "clientArchiveName": "skymp-client.zip",
    "launcherUpdatePublicUrl": "http://localhost:4000/launcher-updates"
  },
  "storage": {
    "dataDir": "data"
  },
  "features": {
    "discordBot": true,
    "websocketRelay": true,
    "githubWebhook": true,
    "legacyDirectSessionCreation": false,
    "apiDocs": true
  }
}
